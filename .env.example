# Local Postgres configuration for the property estimator
# Use either DATABASE_URL or the PG* variables below.

# Option 1: single connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/property_estimator

# Option 2: discrete variables
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=property_estimator

# Enable this only if your provider requires SSL.
# DATABASE_SSL=true
